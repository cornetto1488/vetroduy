@echo off
chcp 65001 > nul
title Сборка TELEMOSTushka

echo =========================================
echo  Удаление старых папок сборки...
echo =========================================

if exist "dist" (
    echo Удаляю папку dist...
    rmdir /s /q "dist"
)

echo.
echo =========================================
echo  Очистка кэша npm...
echo =========================================
call npm cache verify

echo.
echo =========================================
echo  Запуск полной сборки TELEMOSTushka...
echo =========================================
echo.

:: Запускаем скрипт "dist"
call npm run dist

if %ERRORLEVEL% NEQ 0 (
    echo.
    echo =========================================
    echo  [ОШИБКА] Сборка завершилась с ошибкой!
    echo =========================================
    echo Код ошибки: %ERRORLEVEL%
) else (
    echo.
    echo =========================================
    echo  [УСПЕХ] Сборка успешно завершена!
    echo =========================================
    echo Исполняемый файл и инсталлятор находятся в папке: \dist
)

echo.
pause