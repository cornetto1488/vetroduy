{
  "name": "vetroduy",
  "productName": "ВЕТРОДУЙ",
  "version": "2.0.0",
  "description": "Discord-подобный клиент с комнатами на базе Яндекс Телемоста",
  "author": {
    "name": "VETRODUY"
  },
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "ru.vetroduy.app",
    "productName": "ВЕТРОДУЙ",
    "artifactName": "VETRODUY-Setup-${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "bin",
          "to": "bin",
          "filter": [
            "yt-dlp.exe"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "tar.gz"
      ],
      "icon": "build/icon.png",
      "category": "Network",
      "executableName": "vetroduy"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "vosk-browser": "^0.0.8"
  }
}
